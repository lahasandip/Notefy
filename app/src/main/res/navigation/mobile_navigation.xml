<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation.xml"
    app:startDestination="@id/home">

    <fragment
        android:id="@+id/home"
        android:name="com.sandip.notefy.ui.home.Home"
        android:label="home"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_home_to_new_update_note"
            app:destination="@id/new_update_note"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/new_update_note"
        android:name="com.sandip.notefy.ui.newupdate.NewUpdateNote"
        android:label="new_update"
        tools:layout="@layout/fragment_new_update_note" >

        <argument
            android:name="home"
            android:defaultValue="@null"
            app:argType="com.sandip.notefy.data.NoteEntity"
            app:nullable="true" />
        <argument
            android:name="todo"
            android:defaultValue="@null"
            app:argType="com.sandip.notefy.data.TodoEntity"
            app:nullable="true" />
        <argument
            android:name="title"
            app:argType="string" />
        <action
            android:id="@+id/action_new_update_note_to_todo"
            app:destination="@id/todo" />

    </fragment>
    <dialog
        android:id="@+id/todo"
        android:name="com.sandip.notefy.ui.todo.Todo"
        android:label="todo">
        <action
            android:id="@+id/action_todo_to_new_update_note"
            app:destination="@id/new_update_note" />
    </dialog>


</navigation>