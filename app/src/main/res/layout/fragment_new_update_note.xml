            <LinearLayout
                android:id="@+id/url_link_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/url_link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:autoLink="web"
                    android:textSize="16sp"
                    android:textColor="@color/purple_700"
                    android:theme="@style/SearchView"
                    />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/reminder_layout"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/search_view"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/clock"
                    android:layout_width="25dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="10dp"
                    android:src="@drawable/ic_outline_access_alarms_24" />

                <TextView
                    android:id="@+id/date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="10dp"
                    android:background="@null"
                    android:textSize="16dp"
                    android:theme="@style/SearchView" />

                <TextView
                    android:id="@+id/time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:layout_marginTop="10dp"
                    android:background="@null"
                    android:textSize="16dp"
                    android:theme="@style/SearchView" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/location_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:visibility="gone"
                android:background="@drawable/search_view"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="10dp"
                    android:src="@drawable/ic_outline_location_on_24" />

                <TextView
                    android:id="@+id/place_input"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="15dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="10dp"
                    android:background="@null"
                    android:textSize="16dp"
                    android:theme="@style/SearchView" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/task_layout"
                android:layout_width="45dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/search_view"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="10dp"
                    android:src="@drawable/ic_outline_checklist_24" />
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/sandip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/header"
                android:layout_marginTop="100dp"
                android:layout_marginBottom="50dp"
                android:scrollbars="none" />
        <LinearLayout
            android:id="@+id/todo_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/search_view"
            android:orientation="horizontal"
            android:visibility="gone">

            <include
                android:id="@+id/todo"
                layout="@layout/todo_listview"/>




        </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottom_nav_layout"
        android:layout_width="match_parent"
        android:layout_height="47dp"
        android:layout_margin="5dp"
        android:padding="5dp"
        android:background="@drawable/popup_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/new_update_guideline_2"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@+id/new_update_guideline_1">


        <ImageView
            android:id="@+id/add_features"
            android:layout_width="25dp"
            android:layout_height="40dp"
            android:layout_marginStart="5dp"
            android:layout_marginBottom="5dp"
            android:src="@drawable/ic_outline_add_box_24"/>

        <ImageView
            android:id="@+id/add_color"
            android:layout_width="25dp"
            android:layout_height="40dp"
            android:layout_marginStart="28dp"
            android:layout_marginBottom="5dp"
            android:src="@drawable/ic_outline_color_lens_24"/>

        <ImageView
            android:id="@+id/add_image"
            android:layout_width="25dp"
            android:layout_height="40dp"
            android:layout_marginStart="28dp"
            android:layout_marginBottom="5dp"
            android:src="@drawable/ic_outline_image_24" />

        <ImageView
            android:id="@+id/add_task"
            android:layout_width="25dp"
            android:layout_height="40dp"
            android:layout_marginStart="28dp"
            android:layout_marginBottom="5dp"
            android:src="@drawable/ic_outline_checklist_24" />


    </LinearLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/new_update_guideline_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="15dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/new_update_guideline_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_end="15dp" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/save_note"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="15dp"
        android:layout_marginBottom="25dp"
        android:elevation="10dp"
        android:src="@drawable/ic_baseline_done_24"
        app:layout_constraintBottom_toBottomOf="@+id/bottom_nav_layout"
        app:layout_constraintEnd_toStartOf="@+id/new_update_guideline_2" />


</androidx.constraintlayout.widget.ConstraintLayout>