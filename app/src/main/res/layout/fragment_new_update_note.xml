<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragment_newUpdateNote"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.sandip.notefy.ui.newupdate.NewUpdateNote"
    >

    <ImageView
        android:id="@+id/back"
        android:layout_width="25dp"
        android:layout_height="40dp"
        android:layout_marginTop="5dp"
        android:src="@drawable/ic_baseline_arrow_back_24"
        app:layout_constraintStart_toStartOf="@+id/new_update_guideline_1"
        app:layout_constraintTop_toTopOf="parent" />


    <CheckBox
        android:id="@+id/important"
        android:layout_width="25dp"
        android:layout_height="40dp"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="25dp"
        android:button="@drawable/ic_baseline_bookmark_border_24"
        app:layout_constraintEnd_toStartOf="@+id/delete_note"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/delete_note"
        android:layout_width="25dp"
        android:layout_height="40dp"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="25dp"
        android:src="@drawable/ic_baseline_delete_outline_24"
        app:layout_constraintEnd_toStartOf="@+id/share"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/share"
        android:layout_width="25dp"
        android:layout_height="35dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/ic_baseline_share_24"
        app:layout_constraintEnd_toStartOf="@+id/new_update_guideline_2"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/note_edited"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:text="xcxccxcxcxcxxcxcxcx"
        android:textSize="14dp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav_layout"
        app:layout_constraintEnd_toStartOf="@+id/new_update_guideline_2"
        app:layout_constraintHorizontal_bias="0.485"
        app:layout_constraintStart_toStartOf="@+id/new_update_guideline_1" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="60dp"
        android:layout_marginBottom="80dp"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav_layout"
        app:layout_constraintEnd_toStartOf="@+id/new_update_guideline_2"
        app:layout_constraintStart_toStartOf="@+id/new_update_guideline_1"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            android:orientation="vertical">


            <ImageView
                android:id="@+id/show_image"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:scaleType="fitXY"
                android:visibility="gone"/>

            <EditText
                android:id="@+id/note_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="Title"
                android:scrollbars="none"
                android:textSize="25dp"
                android:theme="@style/SearchView" />

            <EditText
                android:id="@+id/note_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="5dp"
                android:background="@null"
                android:hint="Note"
                android:textSize="20dp"
                android:theme="@style/SearchView" />
